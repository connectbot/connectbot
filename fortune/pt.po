#. Summary of what ConnectBot is; used as a short description in the Android
#. running apps list
msgctxt "app_desc"
msgid "Simple, powerful, open-source SSH client."
msgstr "Cliente SSH simples, avançado e de código aberto."

#. Summary of what the ConnectBot service does; displayed in the Android
#. running apps list
msgctxt "service_desc"
msgid "Maintains SSH connections and loaded pubkeys"
msgstr "Mantém ligações SSH e de Chaves Públicas"

#. Displayed in the "Help" screen to denote the copyright of this app.
msgctxt "app_copyright"
msgid "Copyright © Kenny Root"
msgstr "Direitos autorais © Kenny Root"

#. Window title for the Pubkeys List
msgctxt "title_pubkey_list"
msgid "Pubkeys"
msgstr "Chaves Públicas"

#. Window title for the Port Forwards List
msgctxt "title_port_forwards_list"
msgid "Port forwards"
msgstr "Redirecionamento de portas"

#. Window title for Help index
msgctxt "title_help"
msgid "Help"
msgstr "Ajuda"

#. Window title for the license/EULA screen
msgctxt "title_eula"
msgid "License"
msgstr "Licença"

#. Window title for color list editing screen
msgctxt "title_colors"
msgid "Colors"
msgstr "Cores"

#. Dialog title for color picker dialog
msgctxt "title_color_picker"
msgid "Pick a color"
msgstr "Selecione uma cor"

#. Window title for the global applications settings activity.
msgctxt "title_settings"
msgid "Settings"
msgstr "Definições"

#. Window title when generating a new pubkey.
msgctxt "title_pubkey_generate"
msgid "Generate"
msgstr "Gerar"

#. Title for the help page with the terms & conditions of the app.
msgctxt "terms_and_conditions"
msgid "Terms & Conditions"
msgstr "Termos & Condições"

#. Title for the help page with the hints about the app.
msgctxt "hints"
msgid "Hints"
msgstr "Sugestões"

#. Title for the help dialog showing keyboard shortcuts.
msgctxt "keyboard_shortcuts"
msgid "Keyboard Shortcuts"
msgstr "Teclas de atalho"

#. Text in a keyboard shortcuts list lined up to keys which increase the
#. terminal font-size.
msgctxt "increase_font_size"
msgid "Increase Font Size"
msgstr "Aumentar o Tamanho de Letra"

#. Keyboard shortcut for increasing the font size.
msgctxt "increase_font_shortcut"
msgid "Ctrl and +"
msgstr "Ctrl +"

#. Text in a keyboard shortcuts list lined up to keys which decrease the
#. terminal font-size.
msgctxt "decrease_font_size"
msgid "Decrease Font Size"
msgstr "Diminuir o Tamanho de Letra"

#. Keyboard shortcut for decreasing the font size.
msgctxt "decrease_font_shortcut"
msgid "Ctrl and -"
msgstr "Ctrl -"

#. Keyboard shortcut for pasting into the terminal.
msgctxt "paste_shortcut"
msgid "Ctrl-Shift-V"
msgstr "Ctrl-Shift-V"

#. Button text to generate a new SSH public/private key pair
msgctxt "pubkey_generate"
msgid "Generate"
msgstr "Gerar"

#. Context menu action to delete a saved public key
msgctxt "pubkey_delete"
msgid "Delete key"
msgstr "Apagar chave"

#. Dialog title when user must move finger randomly over an area to gather
#. entropy (collect random bits)
msgctxt "pubkey_gather_entropy"
msgid "Gathering Entropy"
msgstr "A recolher entropia"

#. Progress message showing percentage of random data collected for key
#. generation
#, c-format
msgctxt "pubkey_touch_prompt"
msgid "Touch this box to gather randomness: %1$d%% done"
msgstr "Toque nesta caixa para gerar aleariedade: %1$d%% completo"

#. Instructions to user on how to provide randomness by moving their finger
#. over the screen
msgctxt "pubkey_touch_hint"
msgid ""
"In order to assure randomness during the key generation, move your finger"
" randomly over the box below."
msgstr ""
"Para garantir a aleatoriedade durante a geração da chave, mova o dedo "
"aleatoriamente sobre a caixa abaixo."

#. Progress message shown while generating a new SSH key pair
msgctxt "pubkey_generating"
msgid "Generating key pair…"
msgstr "A gerar par de chaves…"

#. Context menu action to copy the private key to clipboard in the default
#. format
msgctxt "pubkey_copy_private"
msgid "Copy private key"
msgstr "Copiar chave privada"

#. Context menu action to copy the private key to clipboard in OpenSSH format
msgctxt "pubkey_copy_private_openssh"
msgid "Copy private key (OpenSSH)"
msgstr "Copie a chave privada (OpenSSH)"

#. Context menu action to copy the private key to clipboard in PEM format
msgctxt "pubkey_copy_private_pem"
msgid "Copy private key (PEM)"
msgstr "Copie a chave privada (PEM)"

#. Context menu action to copy the encrypted private key to clipboard
msgctxt "pubkey_copy_private_encrypted"
msgid "Copy private key (encrypted)"
msgstr "Copiar chave privada (criptografada)"

#. Context menu action to copy the public key to clipboard
msgctxt "pubkey_copy_public"
msgid "Copy public key"
msgstr "Copiar chave pública"

#. Context menu action to export the public key to a file
msgctxt "pubkey_export_public"
msgid "Export public key"
msgstr "Exporte a chave pública"

#. Context menu action to export the private key to a file in the default
#. format
msgctxt "pubkey_export_private"
msgid "Export private key"
msgstr "Exportar chave privada"

#. Context menu action to export the private key to a file in OpenSSH format
msgctxt "pubkey_export_private_openssh"
msgid "Export private key (OpenSSH)"
msgstr "Exportar chave privada (OpenSSH)"

#. Context menu action to export the private key to a file in PEM format
msgctxt "pubkey_export_private_pem"
msgid "Export private key (PEM)"
msgstr "Exportar chave privada (PEM)"

#. Context menu action to export the encrypted private key to a file
msgctxt "pubkey_export_private_encrypted"
msgid "Export private key (encrypted)"
msgstr "Exportar chave privada (criptografada)"

#. Dialog title for setting a passphrase when exporting a key
msgctxt "pubkey_export_set_passphrase"
msgid "Set export passphrase"
msgstr "Definir a frase secreta para exportação"

#. Instructions to enter a passphrase to encrypt the key being exported
msgctxt "pubkey_export_passphrase_message"
msgid "Enter a passphrase to encrypt the exported key"
msgstr "Insira uma senha para criptografar a chave exportada"

#. Label for the field where user confirms the passphrase by entering it again
msgctxt "pubkey_export_confirm_passphrase"
msgid "Confirm passphrase"
msgstr "Confirme a frase secreta"

#. Error message shown when the passphrase and confirmation passphrase don't
#. match
msgctxt "pubkey_export_passphrase_mismatch"
msgid "Passphrases do not match"
msgstr "As frases-senha não correspondem"

#. Dialog title when importing an encrypted SSH key file
msgctxt "pubkey_import_encrypted_title"
msgid "Import encrypted key"
msgstr "Importar chave criptografada"

#. Prompt asking user to enter the password to decrypt an imported key file.
#. First parameter is key nickname, second is key type.
#, c-format
msgctxt "pubkey_import_encrypted_message"
msgid "Enter password to decrypt key '%1$s' (%2$s)"
msgstr "Insira a senha para descriptografar a chave '%1$s' (%2$s)"

#. Button text to confirm importing a key
msgctxt "pubkey_import_button"
msgid "Import"
msgstr "Importar"

#. Checkbox label in the import encrypted key dialog. When checked, the
#. imported key will be encrypted for storage on the device.
msgctxt "pubkey_import_encrypt_key"
msgid "Encrypt key for storage"
msgstr "Criptografar a chave para armazenamento"

#. Checkbox label that appears when 'Encrypt key for storage' is checked. When
#. checked, the same password used to decrypt the imported key will be used to
#. encrypt it for storage.
msgctxt "pubkey_import_reuse_password"
msgid "Use same password for encryption"
msgstr "Use a mesma senha para criptografia"

#. Label for the password field when entering a new password to encrypt the
#. imported key for storage.
msgctxt "pubkey_import_new_password"
msgid "New password"
msgstr "Nova senha"

#. Label for the password confirmation field when setting a new password to
#. encrypt the imported key.
msgctxt "pubkey_import_confirm_password"
msgid "Confirm password"
msgstr "Confirme a senha"

#. Note that the '\n' just splits lines, so it's actually "create or import"
msgctxt "pubkey_list_empty"
msgid ""
"Tap \"Menu\" to create\n"
"or import key pairs."
msgstr "Toque em \"Menu\" para criar ou importar pares de chaves."

msgctxt "pubkey_unknown_format"
msgid "Unknown format"
msgstr "Formato desconhecido"

#. Context menu action to change the password protecting a private key
msgctxt "pubkey_change_password"
msgid "Change password"
msgstr "Alterar palavra-passe"

#. Context menu action to unlock an encrypted key for use in authentication
msgctxt "pubkey_unlock"
msgid "Unlock key"
msgstr "Desbloquear chave"

#. Dialog message prompting the user to enter password to unlock an encrypted
#. key.
#, c-format
msgctxt "pubkey_unlock_message"
msgid "Enter password to unlock key '%1$s'"
msgstr "Insira a senha para desbloquear a chave '%1$s'"

#. Error message shown when user tries to use a nickname that already exists
#. for another key.
msgctxt "pubkey_nickname_exists"
msgid "A key with this nickname already exists"
msgstr "Já existe uma chave com este apelido"

#. Context menu checkbox that indicates that this pubkey entry should attempt
#. to be loaded upon starting the app.
msgctxt "pubkey_load_on_start"
msgid "Load key on start"
msgstr "Carregar chave ao iniciar"

#. Pubkey preference asking user whether the key use should be confirmed via
#. prompt before it can be used for authentication
msgctxt "pubkey_confirm_use"
msgid "Confirm before use"
msgstr "Confirmar antes de usar"

#. Context menu action where a user can edite the selected port forward for
#. the host.
msgctxt "portforward_edit"
msgid "Edit port forward"
msgstr "Editar encaminhamento de porta"

#. Context menu action where a user can delete the selected port forward from
#. the host.
msgctxt "portforward_delete"
msgid "Delete port forward"
msgstr "Apagar encaminhamento de porta"

#. Label for the input field where user enters a nickname for a host or key
msgctxt "prompt_nickname"
msgid "Nickname:"
msgstr "Apelido:"

#. The source TCP port for port forwards.
msgctxt "prompt_source_port"
msgid "Source port:"
msgstr "Porta de origem:"

#. The "host:port" combination used for port forward destinations.
msgctxt "prompt_destination"
msgid "Destination:"
msgstr "Destino:"

#. Prompt presented to the user when the server requests that they change
#. their password. This is the entry for the old password.
msgctxt "prompt_old_password"
msgid "Old password:"
msgstr "Palavra-passe antiga:"

#. Prompt for user to enter their username when the host has no username
#. configured.
msgctxt "prompt_username"
msgid "Username:"
msgstr "Nome de usuário:"

#. Prompt for user to enter their password to log into the host when using
#. 'password' authentication.
msgctxt "prompt_password"
msgid "Password:"
msgstr "Palavra-passe:"

#. Added after a "Password:" prompt to indicate user needs to confirm entry.
msgctxt "prompt_again"
msgid "(again)"
msgstr "(novamente)"

#. Label for the user to select port forward type.
msgctxt "prompt_type"
msgid "Type:"
msgstr "Tipo:"

#. Hint given below the password input box that lets them know that they are
#. allowed to leave the field blank.
msgctxt "prompt_password_can_be_blank"
msgid "Note: password can be blank"
msgstr "Nota: a palavra-passe pode ficar em branco"

#. Prompt for the size of the private key in bits.
msgctxt "prompt_bits"
msgid "Bits:"
msgstr "Bits:"

#. Prompt for the password to unlock a certain pubkey.
#, c-format
msgctxt "prompt_pubkey_password"
msgid "Password for key '%1$s'"
msgstr "Palavra-passe para a chave '%1$s'"

#. Prompt for whether to allow SSH Authentication Agent to use the specified
#. key. Note that the '\n' means split the line so it's actually "host to use
#. key"
#, c-format
msgctxt "prompt_allow_agent_to_use_key"
msgid ""
"Allow remote host to\n"
"use key '%1$s'?"
msgstr ""
"Permitir ao servidor remoto\n"
"usar a chave '%1$s'?"

#. The header of the warning a user gets when the host key has changed. Note
#. that this can be a very serious attack, so we try to be as "loud" to the
#. user as possible.
msgctxt "host_verification_failure_warning_header"
msgid "WARNING: REMOTE HOST IDENTIFICATION HAS CHANGED!"
msgstr "ATENÇÃO: A IDENTIFICAÇÃO DO SERVIDOR REMOTO MUDOU!"

#. The body of the warning a user gets when the host key has changed. Note
#. that this can be a very serious attack, so we try to be as "loud" to the
#. user as possible.
msgctxt "host_verification_failure_warning"
msgid ""
"IT IS POSSIBLE THAT SOMEONE IS DOING SOMETHING NASTY!\n"
"Someone could be eavesdropping on you right now (man-in-the-middle "
"attack)!\n"
"It is also possible that the host key has just been changed."
msgstr ""
"É POSSÍVEL QUE ALGUÉM ESTEJA QUERENDO TE ENGANAR!\n"
"Alguém pode estar a tentar um ataque do tipo man-in-the-middle!\n"
"Também é possível que a chave do servidor remoto tenha mesmo sido "
"modificada."

#. Prompt user gets when the remote host has disconnected unexpectedly.
msgctxt "prompt_host_disconnected"
msgid ""
"Host has disconnected.\n"
"Close session?"
msgstr ""
"Servidor desconectou-se\n"
"Fechar sessão?"

#. Prompt user must answer yes or no to when the remote host fails
#. verification of encryption fingerprint
#, fuzzy
msgctxt "prompt_continue_connecting"
msgid "Are you sure you want to continue connecting?"
msgstr ""
"Tem a certeza que quer\n"
"continuar a connectar?"

#. Sent to user when the remote public encryption key fingerprint doesn't
#. match the local database
#, c-format
msgctxt "host_authenticity_warning"
msgid "The authenticity of host '%1$s' can't be established."
msgstr "A autenticidade do servidor '%1$s' não pode ser verificada."

#. First field is encryption algorithm. Second is the actual fingerprint in
#. hex digits
#, c-format
msgctxt "host_fingerprint"
msgid "Host %1$s key fingerprint is %2$s"
msgstr "O servidor %1$s tem a impressão digital %2$s"

#. Title for the host key fingerprint verification prompt shown when
#. connecting to a new host
msgctxt "host_key_verification_title"
msgid "Host key verification"
msgstr "Verificação da chave do host"

#. Section header for the fingerprint formats display area
msgctxt "fingerprint_format_header"
msgid "Fingerprint format"
msgstr "Formato da impressão digital"

#. Format string showing key type and size, e.g., "RSA 2048 bits". First field
#. is key type, second is key size in bits.
#, c-format
msgctxt "host_key_type_and_size"
msgid "%1$s %2$d bits"
msgstr "%1$s %2$d bits"

#. Content description for the copy fingerprint to clipboard button, used by
#. screen readers for accessibility
msgctxt "fingerprint_copy_description"
msgid "Copy fingerprint to clipboard"
msgstr "Copie a impressão digital para a área de transferência"

#. Error message shown when entered password and confirmation password don't
#. match
msgctxt "alert_passwords_do_not_match_msg"
msgid "Passwords do not match!"
msgstr "As palavras-passe não coincidem!"

#. Error message shown when user enters an incorrect password
msgctxt "alert_wrong_password_msg"
msgid "Wrong password!"
msgstr "Palavra-passe errada!"

#. Button that resizes the screen to the user-specified dimensions.
msgctxt "button_resize"
msgid "Resize"
msgstr "Redimensionar"

#. Alert dialog title shown when connection to the remote host is lost
msgctxt "alert_disconnect_msg"
msgid "Connection Lost"
msgstr "Ligação Perdida"

#. Message shown when network connection is lost and app is waiting to
#. reconnect
msgctxt "network_lost_grace_period"
msgid "Network lost, waiting to reconnect…"
msgstr "Rede desconectada, aguardando para reconectar…"

#. Message shown when the 60-second grace period expires without network
#. restoration
msgctxt "network_grace_period_expired"
msgid "Network not restored, disconnecting…"
msgstr "Rede não restabelecida, desconectando…"

#. Message shown when network is restored and connection can continue (same IP
#. address)
msgctxt "network_restored_same_ip"
msgid "Network restored, connection maintained"
msgstr "Rede restabelecida, conexão mantida"

#. Message shown when network is restored but IP address changed, requiring
#. reconnection
msgctxt "network_restored_ip_changed"
msgid "Network restored but IP changed, reconnecting…"
msgstr "Rede restabelecida, mas o endereço IP foi alterado, reconectando…"

#. Message shown when network is restored but previous network state is
#. unknown
msgctxt "network_restored_no_previous_state"
msgid "Network restored, verifying connection…"
msgstr "Rede restabelecida, verificando a conexão…"

#. The category title for terminal emulation preferences.
msgctxt "pref_emulation_category"
msgid "Terminal emulation"
msgstr "Emulação de Terminal"

#. Name for the emulation terminal type preference.
msgctxt "pref_emulation_title"
msgid "Emulation mode"
msgstr "Modo de emulação"

#. Description of the emulation terminal type preference.
#. Name for the scrollback size preference
msgctxt "pref_scrollback_title"
msgid "Scrollback size"
msgstr "Tamanho do buffer"

#. Description of the scrollback size preference
msgctxt "pref_scrollback_summary"
msgid "Size of scrollback buffer to keep in memory for each console"
msgstr "Tamanho do buffer em memória para cada consola"

#. Name for the font family preference
msgctxt "pref_fontfamily_title"
msgid "Font"
msgstr "Fonte"

#. Description of the font family preference
#. Title for adding custom font
msgctxt "pref_customfont_title"
msgid "Add custom font"
msgstr "Adicionar fonte personalizada"

#. Summary for adding custom font
msgctxt "pref_customfont_summary"
msgid "Add a font from Google Fonts by name"
msgstr "Adicione uma fonte do Google Fonts pelo nome"

#. Dialog title for adding custom font
msgctxt "dialog_customfont_title"
msgid "Add Custom Font"
msgstr "Adicionar fonte personalizada"

#. Hint for custom font name input
msgctxt "dialog_customfont_hint"
msgid "Google Fonts name (e.g., Cascadia Code)"
msgstr "Nome da fonte do Google (por exemplo, Cascadia Code)"

#. Button to add font
msgctxt "button_add"
msgid "Add"
msgstr "Adicionar"

#. Button to remove font
msgctxt "button_remove"
msgid "Remove"
msgstr "Remova"

#. Message shown when validating font
msgctxt "font_validating"
msgid "Validating font…"
msgstr "Validando a fonte…"

#. Message shown while downloading a font from Google Fonts
msgctxt "font_downloading"
msgid "Downloading font…"
msgstr "A baixar a fonte…"

#. Title for importing local font
msgctxt "pref_localfont_title"
msgid "Import local font"
msgstr "Importar fonte local"

#. Summary for importing local font
msgctxt "pref_localfont_summary"
msgid "Import a font file from storage (TTF, OTF)"
msgstr "Importe um arquivo de fonte do armazenamento (TTF, OTF)"

#. Dialog title for importing local font
msgctxt "dialog_localfont_title"
msgid "Import Font"
msgstr "Importar fonte"

#. Hint for local font name input
msgctxt "dialog_localfont_hint"
msgid "Display name for the font"
msgstr "Nome de exibição da fonte"

#. Button to import font
msgctxt "button_import"
msgid "Import"
msgstr "Importar"

#. Message shown when importing font
msgctxt "font_importing"
msgid "Importing font…"
msgstr "Importando fonte…"

#. Title of the preference used to enable or disable the back-up of pubkeys.
msgctxt "pref_backupkeys_title"
msgid "Backup pubkeys"
msgstr "Cópias de segurança das chaves publicas"

#. Summary for the preference used to enable or disable the back-up of
#. pubkeys.
msgctxt "pref_backupkeys_summary"
msgid "Keep back-ups of the private keys using Android's backup mechanism"
msgstr ""
"Manter cópias de segurança das chaves privadas usando o sistema de cópia "
"de segurança do Android"

#. The category title for user interface preferences
msgctxt "pref_ui_category"
msgid "User interface"
msgstr "Interface de utilizador"

#. Name for the language preference
msgctxt "pref_language_title"
msgid "Language"
msgstr "Idioma"

#. Default option for language preference that uses the system locale
msgctxt "pref_language_system_default"
msgid "System default"
msgstr "Padrão do sistema"

#. Title of the theme mode selector preference in the User Interface settings
#. section
msgctxt "pref_theme_title"
msgid "Theme"
msgstr "Tema"

#. Theme option: follow the OS light/dark setting
msgctxt "pref_theme_system"
msgid "System default"
msgstr "Padrão do sistema"

#. Theme option: always use the light theme regardless of OS setting
msgctxt "pref_theme_light"
msgid "Light"
msgstr "Leve"

#. Theme option: always use the dark theme regardless of OS setting
msgctxt "pref_theme_dark"
msgid "Dark"
msgstr "Escuro"

#. Name for the rotation mode preference
msgctxt "pref_rotation_title"
msgid "Rotation mode"
msgstr "Rotação de ecrã"

#. Name for the titlebar hide preference
msgctxt "pref_titlebarhide_title"
msgid "Autohide title bar"
msgstr "Esconder automaticamente a barra de título"

#. Summary for the titlebar hide preference
msgctxt "pref_titlebarhide_summary"
msgid "Tap console to show title bar and access menu"
msgstr "Pressione no terminal para mostrar a barra de título e o menu de acesso"

#. Title for special keys always visible preference
msgctxt "pref_alwaysvisible_title"
msgid "Special keys always visible"
msgstr "Teclas especiais sempre visiveis"

#. Name for the page up/down gesture preference
msgctxt "pref_pg_updn_gesture_title"
msgid "Page up/down gesture"
msgstr "Gesto de pag. acima/pag. abaixo"

#. Summary for the full screen preference
msgctxt "pref_pg_updn_gesture_summary"
msgid "Swipe the left third of the screen to send pg up/dn to the terminal"
msgstr ""
"Passe sobre a terceira parte da tela à esquerda para enviar comandos de "
"página acima/página abaixo para o terminal"

#. Name for the full screen preference
msgctxt "pref_fullscreen_title"
msgid "Full screen"
msgstr "Ecrã inteiro"

#. Summary for the full screen preference
msgctxt "pref_fullscreen_summary"
msgid "Hide status bar while in console"
msgstr "Esconder a barra de notificação quando estiver no terminal"

#. The category title for keyboard preferences
msgctxt "pref_keyboard_category"
msgid "Keyboard"
msgstr "Teclado"

#. Name for the shifted numbers are f-keys preference
msgctxt "pref_shiftfkeys_title"
msgid "Shift+num are F-keys"
msgstr "Shift+número são as teclas F"

#. Summary for the shifted numbers are f-keys preference
msgctxt "pref_shiftfkeys_summary"
msgid "On hardware keyboards, number keys send F1-F10 with shift"
msgstr "Em teclados físicos, as teclas numéricas enviam F1-F10 com shift"

#. Name for the ctrl'ed numbers are f-keys preference
msgctxt "pref_ctrlfkeys_title"
msgid "Ctrl+num are F-keys"
msgstr "Ctrl+número são as teclas F"

#. Summary for the ctrl'ed numbers are f-keys preference
msgctxt "pref_ctrlfkeys_summary"
msgid "On software keyboards, number keys send F1-F10 with ctrl"
msgstr "Em teclados virtuais, as teclas numéricas enviam F1-F10 com shift"

#. Name for the volume keys control font size preference
msgctxt "pref_volumefont_title"
msgid "Volume keys change font size"
msgstr "Teclas de volume alteram o tamanho da letra"

#. Summary for the volume keys control font size preference
#, fuzzy
msgctxt "pref_volumefont_summary"
msgid "Font size can also be changed in profile settings"
msgstr "O tamanho da letra pode ser alterado nas definições do servidor"

#. Name for the memorize keys preference
msgctxt "pref_memkeys_title"
msgid "Remember keys in memory"
msgstr "Lembrar chaves em memória"

#. Summary for the memorize keys preference
msgctxt "pref_memkeys_summary"
msgid "Keep unlocked keys in memory until backend service is terminated"
msgstr ""
"Mantenha as chaves desbloqueadas na memória até que o serviço de back-end"
" seja encerrado."

#. Name for the preference that forces the service to stay running in the
#. background.
msgctxt "pref_conn_persist_title"
msgid "Persist connections"
msgstr "Ligações persistentes"

#. Summary for the preference that forces the service to stay running in the
#. background.
msgctxt "pref_conn_persist_summary"
msgid "Force connections to stay connected while in background"
msgstr "Forçar ligações a ficarem ligadas quando em segundo plano"

#. Name for the keyboard shortcuts preference
msgctxt "pref_keymode_title"
msgid "Directory shortcuts"
msgstr "Teclas de atalho"

#. Name for the sticky modifiers preference
msgctxt "pref_stickymodifiers_title"
msgid "Sticky modifiers"
msgstr "Modificadores com teclas presas"

#. Sticky modifier preference value description for when only the Alt key
#. should be a sticky modifier.
msgctxt "only_alt"
msgid "Only alt"
msgstr "Apenas alt"

#. Name for the camera shortcut usage preference
msgctxt "pref_camera_title"
msgid "Camera shortcut"
msgstr "Botão da câmara"

#. Name for the keep screen on preference
msgctxt "pref_keepalive_title"
msgid "Keep screen awake"
